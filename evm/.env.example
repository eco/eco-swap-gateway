# Deployer private key (with 0x prefix)
PRIVATE_KEY=

# Deployment salt (bytes32 hex). CreateX hashes this internally, so any
# random value works. The same salt + portal address = same contract address
# on every chain, regardless of deployer.
# Example: keccak256("eco-swap-intent-v1")
SALT=

# Portal contract address (same on all chains)
PORTAL_ADDRESS=

# Chain configuration JSON — URL or local file path.
# Format: { "<chainId>": { "url": "<rpc_url>", "gasMultiplier": "<optional>" } }
CHAIN_DATA_URL=

# Path to write deployment results CSV
RESULTS_FILE=out/deploy.csv

# (Optional) Alchemy API key if RPC URLs contain ${ALCHEMY_API_KEY}
ALCHEMY_API_KEY=

# (Optional) Set to "true" to append to existing results file
APPEND_RESULTS=false

# Block explorer API keys for verification (JSON: chainId → API key)
# Get keys from: etherscan.io, basescan.org, arbiscan.io, etc.
VERIFICATION_KEYS=
