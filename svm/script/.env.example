# Solana user who signs `[open, <Jupiter>, close_and_select_intent]`. Base58.
# Needs PENGU balance on mainnet (or whatever input token you configure) and
# SOL for fees + ALT rent.
USER_SECRET_KEY=

# EVM private key used as (a) the destination reward creator on-chain and
# (b) the demo "solver" that fulfills on Base. 0x-prefixed hex. Needs Base
# ETH for gas and Base USDC to pay the route amount on fulfill.
EVM_PRIVATE_KEY=

# RPC endpoints.
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
BASE_RPC_URL=https://mainnet.base.org

# Optional: override the input amount (default: 100 PENGU).
PENGU_INPUT=100
